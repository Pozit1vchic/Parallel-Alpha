"""Neural pose verification helpers powered by Ollama."""

from __future__ import annotations

import logging
import re
from typing import Any, Dict, List, Tuple

import numpy as np
import ollama

logger = logging.getLogger(__name__)


class PoseVerifier:
    """Compare two human poses with an LLM-based semantic verifier."""

    def __init__(self, model: str = "llama3.2:1b", confidence_threshold: float = 0.3) -> None:
        self.model = model
        self.confidence_threshold = float(confidence_threshold)
        self._cache: Dict[Tuple[bytes, bytes], float] = {}

    def _coerce_pose(self, keypoints: np.ndarray) -> np.ndarray:
        """Convert supported keypoint layouts to shape (17, 3)."""
        arr = np.asarray(keypoints, dtype=np.float32)

        if arr.ndim == 1:
            if arr.size == 51:
                arr = arr.reshape(17, 3)
            elif arr.size == 34:
                arr = arr.reshape(17, 2)
            else:
                raise ValueError(f"Unsupported flattened pose size: {arr.size}")

        if arr.ndim == 2 and arr.shape == (17, 2):
            conf = np.ones((17, 1), dtype=np.float32)
            arr = np.concatenate([arr, conf], axis=1)

        if arr.ndim == 2 and arr.shape != (17, 3):
            if arr.size == 51:
                arr = arr.reshape(17, 3)
            elif arr.size == 34:
                arr = np.concatenate([arr.reshape(17, 2), np.ones((17, 1), dtype=np.float32)], axis=1)
            else:
                raise ValueError(f"Unsupported pose shape: {arr.shape}")

        if arr.shape != (17, 3):
            raise ValueError(f"Expected pose shape (17, 3), got {arr.shape}")

        return arr

    def pose_to_text(self, keypoints: np.ndarray) -> str:
        """Convert keypoints to a compact human-readable posture description."""
        pose = self._coerce_pose(keypoints)
        xy = pose[:, :2]
        conf = pose[:, 2]

        def safe_point(idx: int) -> np.ndarray:
            if conf[idx] < self.confidence_threshold:
                return np.array([np.nan, np.nan], dtype=np.float32)
            return xy[idx]

        nose = safe_point(0)
        left_shoulder = safe_point(5)
        right_shoulder = safe_point(6)
        left_elbow = safe_point(7)
        right_elbow = safe_point(8)
        left_wrist = safe_point(9)
        right_wrist = safe_point(10)
        left_hip = safe_point(11)
        right_hip = safe_point(12)
        left_knee = safe_point(13)
        right_knee = safe_point(14)
        left_ankle = safe_point(15)
        right_ankle = safe_point(16)

        def y_state(joint: np.ndarray, ref: np.ndarray, name: str) -> str:
            if np.isnan(joint).any() or np.isnan(ref).any():
                return f"{name}: unknown"
            if joint[1] < ref[1] - 0.08:
                return f"{name}: raised"
            if joint[1] > ref[1] + 0.08:
                return f"{name}: lowered"
            return f"{name}: neutral"

        shoulder_center = np.nanmean(np.vstack([left_shoulder, right_shoulder]), axis=0)
        hip_center = np.nanmean(np.vstack([left_hip, right_hip]), axis=0)

        head_desc = "head: unknown"
        if not np.isnan(nose).any() and not np.isnan(shoulder_center).any():
            tilt = "upright"
            if nose[0] < shoulder_center[0] - 0.06:
                tilt = "tilted left"
            elif nose[0] > shoulder_center[0] + 0.06:
                tilt = "tilted right"
            if nose[1] < shoulder_center[1] - 0.15:
                head_desc = f"head: high, {tilt}"
            else:
                head_desc = f"head: low, {tilt}"

        left_arm = y_state(left_wrist if not np.isnan(left_wrist).any() else left_elbow, left_shoulder, "left arm")
        right_arm = y_state(right_wrist if not np.isnan(right_wrist).any() else right_elbow, right_shoulder, "right arm")

        leg_desc = "legs: unknown"
        if not np.isnan(left_knee).any() and not np.isnan(left_hip).any() and not np.isnan(left_ankle).any():
            left_bent = left_knee[1] - left_hip[1] < 0.35 * max(left_ankle[1] - left_hip[1], 1e-4)
            leg_desc = "legs: left bent" if left_bent else "legs: left extended"
        if not np.isnan(right_knee).any() and not np.isnan(right_hip).any() and not np.isnan(right_ankle).any():
            right_bent = right_knee[1] - right_hip[1] < 0.35 * max(right_ankle[1] - right_hip[1], 1e-4)
            right_text = "right bent" if right_bent else "right extended"
            leg_desc = f"{leg_desc}, {right_text}" if leg_desc != "legs: unknown" else f"legs: {right_text}"

        gaze_desc = "gaze: unknown"
        left_ear = safe_point(3)
        right_ear = safe_point(4)
        if not np.isnan(nose).any() and not np.isnan(left_ear).any() and not np.isnan(right_ear).any():
            ear_center_x = 0.5 * (left_ear[0] + right_ear[0])
            if nose[0] > ear_center_x + 0.03:
                gaze_desc = "gaze: right"
            elif nose[0] < ear_center_x - 0.03:
                gaze_desc = "gaze: left"
            else:
                gaze_desc = "gaze: forward"

        torso_desc = "torso: unknown"
        if not np.isnan(shoulder_center).any() and not np.isnan(hip_center).any():
            if shoulder_center[1] < hip_center[1] - 0.1:
                torso_desc = "torso: upright"
            else:
                torso_desc = "torso: crouched"

        return "; ".join([head_desc, torso_desc, left_arm, right_arm, leg_desc, gaze_desc])

    def compare(self, pose1: np.ndarray, pose2: np.ndarray) -> float:
        """Return LLM-estimated similarity in [0, 1] for two poses."""
        try:
            p1 = self._coerce_pose(pose1)
            p2 = self._coerce_pose(pose2)
        except Exception as exc:
            logger.warning("Pose coercion failed: %s", exc)
            return 0.5

        key = (p1.tobytes(), p2.tobytes())
        rev_key = (key[1], key[0])
        if key in self._cache:
            return self._cache[key]
        if rev_key in self._cache:
            return self._cache[rev_key]

        desc1 = self.pose_to_text(p1)
        desc2 = self.pose_to_text(p2)
        prompt = (
            "Оцени похожесть двух поз человека от 0 до 1. "
            f"Поза 1: {desc1} "
            f"Поза 2: {desc2} "
            "Ответь ТОЛЬКО числом от 0 до 1 с двумя знаками после запятой."
        )

        try:
            response: Any = ollama.chat(
                model=self.model,
                messages=[{"role": "user", "content": prompt}],
                options={"temperature": 0.0},
            )
            text = str(response.get("message", {}).get("content", "")).strip()
            match = re.search(r"\b(?:0(?:\.\d+)?|1(?:\.0+)?)\b", text)
            score = float(match.group(0)) if match else 0.5
            score = float(np.clip(score, 0.0, 1.0))
        except Exception as exc:
            logger.warning("Ollama compare failed: %s", exc)
            score = 0.5

        self._cache[key] = score
        return score


class SimpleReranker:
    """Neural reranker adapter used by matcher candidates."""

    def __init__(self, model: str = "llama3.2:1b") -> None:
        self.verifier = PoseVerifier(model=model)

    def rerank(self, candidates: List[Any], data: Any) -> List[float]:
        """Return neural scores for matcher candidates with best-effort robustness."""
        scores: List[float] = []
        poses = np.asarray(getattr(data, "norm_xy", np.empty((0, 17, 2), dtype=np.float32)))

        for idx, candidate in enumerate(candidates):
            if idx % 50 == 0:
                logger.info("Neural rerank progress: %d/%d", idx, len(candidates))
            try:
                i = int(getattr(candidate, "i"))
                j = int(getattr(candidate, "j"))
                if i < 0 or j < 0 or i >= len(poses) or j >= len(poses):
                    scores.append(0.5)
                    continue
                scores.append(self.verifier.compare(poses[i], poses[j]))
            except Exception as exc:
                logger.warning("Candidate rerank failed at %d: %s", idx, exc)
                scores.append(0.5)

        return scores